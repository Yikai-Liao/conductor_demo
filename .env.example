COMPOSE_PROJECT_NAME=conductor-demo

CONDUCTOR_VERSION=3.22.2
POSTGRES_VERSION=16-alpine
GRAFANA_VERSION=11.5.2
VICTORIA_METRICS_VERSION=v1.112.0
VICTORIA_LOGS_VERSION=v1.18.0-victorialogs
VECTOR_VERSION=0.41.1-debian
OTEL_COLLECTOR_VERSION=0.122.1

POSTGRES_PORT=15432
CONDUCTOR_API_PORT=18080
CONDUCTOR_UI_PORT=18127
REVIEW_SERVICE_PUBLIC_PORT=18090
FUNC1_PUBLIC_PORT=18091
FUNC2_PUBLIC_PORT=18092
OTEL_GRPC_PORT=14317
OTEL_HTTP_PORT=14318
OTEL_PROM_PORT=18889
VMAGENT_PORT=18429
GRAFANA_PORT=13000
VICTORIA_METRICS_PORT=18428
VICTORIA_LOGS_PORT=19428

CONDUCTOR_SERVER_URL=http://localhost:${CONDUCTOR_API_PORT}/api
CONDUCTOR_UI_URL=http://localhost:${CONDUCTOR_UI_PORT}
CONDUCTOR_SWAGGER_URL=http://localhost:${CONDUCTOR_API_PORT}/swagger-ui/index.html
REVIEW_SERVICE_URL=http://localhost:${REVIEW_SERVICE_PUBLIC_PORT}
GRAFANA_URL=http://localhost:${GRAFANA_PORT}
VICTORIA_METRICS_URL=http://localhost:${VICTORIA_METRICS_PORT}
VICTORIA_LOGS_URL=http://localhost:${VICTORIA_LOGS_PORT}

POSTGRES_DB=conductor
POSTGRES_USER=conductor
POSTGRES_PASSWORD=conductor

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

REVIEW_APPROVAL_THRESHOLD=5
REVIEW_MAX_DELAY_MS=5000
REVIEW_REJECT_INCREMENT_MIN=0.10
REVIEW_REJECT_INCREMENT_MAX=1.00

RUN_BULK_COUNT=1000
RUN_BULK_CONCURRENCY=32
AUTO_REVIEW_CONCURRENCY=32
SEARCH_THRESHOLD=10.1
SEARCH_LOOKBACK_DAYS=1
SEARCH_PAGE_SIZE=1000
SEARCH_PROOF_FREETEXT=output.y:>10.1

HTTP_PROXY=
HTTPS_PROXY=
ALL_PROXY=
NO_PROXY=localhost,127.0.0.1,.local
