COMPOSE_PROJECT_NAME=conductor-demo
DOCKER_NETWORK=conductor-demo
PUBLIC_BIND_ADDR=0.0.0.0
LOCAL_BIND_ADDR=127.0.0.1

CONSUL_VERSION=1.19.1
NOMAD_VERSION=1.8.4
VAULT_VERSION=1.17.6
CONDUCTOR_VERSION=3.22.2
POSTGRES_VERSION=16-alpine
GRAFANA_VERSION=11.5.2
VICTORIA_METRICS_VERSION=v1.112.0
VICTORIA_LOGS_VERSION=v1.18.0-victorialogs
VECTOR_VERSION=0.41.1-debian
OTEL_COLLECTOR_VERSION=0.122.1

GATEWAY_PORT=18080
NOMAD_UI_PORT=14646
CONSUL_HTTP_PORT=18500
VAULT_HTTP_PORT=18200
GRAFANA_PORT=13000

GATEWAY_URL=http://localhost:${GATEWAY_PORT}
CONDUCTOR_SERVER_URL=${GATEWAY_URL}/api
CONDUCTOR_UI_URL=${GATEWAY_URL}
CONDUCTOR_SWAGGER_URL=${GATEWAY_URL}/swagger-ui/index.html
REVIEW_SERVICE_URL=${GATEWAY_URL}/review
NOMAD_ADDR=http://127.0.0.1:4646
CONSUL_HTTP_ADDR=http://127.0.0.1:8500
VAULT_ADDR=http://localhost:${VAULT_HTTP_PORT}
GRAFANA_URL=http://localhost:${GRAFANA_PORT}

POSTGRES_DB=conductor
POSTGRES_USER=conductor
POSTGRES_PASSWORD=conductor

REVIEW_API_TOKEN=review-demo-token

CONDUCTOR_UI_IMAGE=conductor-demo/conductor-ui:dev
FUNC1_IMAGE=conductor-demo/func1-python:dev
FUNC2_IMAGE=conductor-demo/func2-ts:dev
REVIEW_SERVICE_IMAGE=conductor-demo/review-service:dev

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

REVIEW_APPROVAL_THRESHOLD=5
REVIEW_MAX_DELAY_MS=0
REVIEW_REJECT_INCREMENT_MIN=0.10
REVIEW_REJECT_INCREMENT_MAX=1.00

RUN_BULK_COUNT=1000
RUN_BULK_CONCURRENCY=32
AUTO_REVIEW_CONCURRENCY=32
SEARCH_THRESHOLD=10.1
SEARCH_LOOKBACK_DAYS=1
SEARCH_PAGE_SIZE=1000
SEARCH_PROOF_FREETEXT='output.y:>10.1'

HTTP_PROXY=
HTTPS_PROXY=
ALL_PROXY=
NO_PROXY=localhost,127.0.0.1,.local,host.docker.internal
